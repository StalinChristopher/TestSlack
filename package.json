{
  "name": "TestSlack",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "cross-env APP_ENV=development expo start",
    "start:dev": "cross-env APP_ENV=development expo start",
    "start:qa": "cross-env APP_ENV=staging expo start",
    "start:prod": "cross-env APP_ENV=production expo start",
    "prebuild:android:dev": "cross-env APP_ENV=development expo prebuild --platform android --clean",
    "prebuild:android:qa": "cross-env APP_ENV=staging expo prebuild --platform android --clean",
    "prebuild:android:prod": "cross-env APP_ENV=production expo prebuild --platform android --clean",
    "prebuild:ios:dev": "cross-env APP_ENV=development expo prebuild --platform ios --clean",
    "prebuild:ios:qa": "cross-env APP_ENV=staging expo prebuild --platform ios --clean",
    "prebuild:ios:prod": "cross-env APP_ENV=production expo prebuild --platform ios --clean",
    "android": "npm run prebuild:android:dev && cross-env APP_ENV=development expo run:android",
    "android:dev": "npm run prebuild:android:dev && cross-env APP_ENV=development expo run:android",
    "android:qa": "npm run prebuild:android:qa && cross-env APP_ENV=staging expo run:android",
    "android:prod": "npm run prebuild:android:prod && cross-env APP_ENV=production expo run:android",
    "android:dev:run": "cross-env APP_ENV=development expo run:android",
    "android:qa:run": "cross-env APP_ENV=staging expo run:android",
    "android:prod:run": "cross-env APP_ENV=production expo run:android",
    "ios": "npm run prebuild:ios:dev && cross-env APP_ENV=development expo run:ios",
    "ios:dev": "npm run prebuild:ios:dev && cross-env APP_ENV=development expo run:ios",
    "ios:qa": "npm run prebuild:ios:qa && cross-env APP_ENV=staging expo run:ios",
    "ios:prod": "npm run prebuild:ios:prod && cross-env APP_ENV=production expo run:ios",
    "ios:dev:run": "cross-env APP_ENV=development expo run:ios",
    "ios:qa:run": "cross-env APP_ENV=staging expo run:ios",
    "ios:prod:run": "cross-env APP_ENV=production expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "format": "prettier --write \"src/**/*.{ts,tsx,js}\" \"App.tsx\" \"index.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js}\" \"App.tsx\" \"index.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "generate:tokens": "node scripts/generate-design-tokens.cjs"
  },
  "overrides": {
    "expo-font": "~55.0.8"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.2.9",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/drawer": "^7.5.0",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "@tanstack/react-query": "^5.62.0",
    "axios": "^1.15.0",
    "expo": "~55.0.26",
    "expo-constants": "~55.0.0",
    "expo-dev-client": "~55.0.35",
    "expo-font": "~55.0.8",
    "expo-linking": "~55.0.15",
    "expo-localization": "~55.0.15",
    "expo-status-bar": "~55.0.6",
    "i18next": "^24.2.3",
    "react": "19.2.0",
    "react-i18next": "^15.4.1",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "4.3.0",
    "react-native-reanimated": "4.2.1",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "@types/react-test-renderer": "^19.1.0",
    "babel-preset-expo": "~55.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "private": true
}
