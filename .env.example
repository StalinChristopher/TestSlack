# Optional: Expo loads this when running in development mode. Do NOT set APP_ENV here.
#
# Copy this file to `.env.development`, `.env.staging`, and/or `.env.production` locally (gitignored).
#
# API URLs for dev/qa/prod are chosen in app.config.ts from APP_ENV (see flavor table there),
# so a single EXPO_PUBLIC_API_BASE_URL in .env.development does not override QA/Prod runs.
# Override only for local development if needed:
# EXPO_PUBLIC_API_BASE_URL=https://my-dev-machine.local:3000/
#
# EAS builds use eas.json `env` per profile (and optional EAS Secrets). Never commit secrets.

EXPO_PUBLIC_APP_ENV=development
